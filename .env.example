# Client-side environment variables (VITE_ prefix - these are bundled into client code)
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_REDIRECT_URI=http://localhost:8888/google-auth-callback
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Server-side environment variables (NOT prefixed with VITE_ - these are only used in Netlify functions)
# These should be configured in Netlify's environment variables dashboard, NOT committed to git
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://your-domain.netlify.app/google-auth-callback
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
FACTURAPI_TEST_SECRET=your_facturapi_test_secret_here
FACTURAPI_LIVE_SECRET=your_facturapi_live_secret_here
FACTURAPI_WEBHOOK_SECRET=your_facturapi_webhook_secret_here

# Document email (Resend) – run `npm run dev:netlify` for local function testing
RESEND_API_KEY=re_your_resend_api_key_here
# For testing: omit or use onboarding@resend.dev (sends only to your Resend account email)
# For production: use verified domain e.g. noreply@yourdomain.com
RESEND_FROM=onboarding@resend.dev

# AI Clinic Chat (Anthropic Claude) – server-side only, powers the ai-chat function
ANTHROPIC_API_KEY=sk-ant-your_api_key_here